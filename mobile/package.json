{
  "name": "sakapuss-mobile",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build:android": "eas build --platform android --profile preview",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:e2e": "for f in .maestro/flows/login.yaml .maestro/flows/full-flow.yaml .maestro/flows/timeline-navigation.yaml .maestro/flows/quick-log-weight.yaml .maestro/flows/pet-profile.yaml .maestro/flows/add-pet.yaml; do ~/.maestro/bin/maestro test \"$f\" || exit 1; done"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.1.0",
    "@react-native-community/netinfo": "11.4.1",
    "@react-navigation/bottom-tabs": "^6.6.1",
    "@react-navigation/native": "^6.1.18",
    "@react-navigation/stack": "^6.4.1",
    "expo": "~52.0.0",
    "expo-status-bar": "~2.0.0",
    "react": "18.3.1",
    "react-native": "0.76.5",
    "react-native-gesture-handler": "~2.20.2",
    "react-native-reanimated": "~3.16.1",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.4.0"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^30.0.0",
    "@types/react": "~18.3.0",
    "jest": "^29.7.0",
    "jest-expo": "^52.0.6",
    "msw": "^2.13.4",
    "typescript": "^5.3.0"
  },
  "private": true
}
