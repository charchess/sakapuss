# ============================================================
# Sakapuss — Environment Variables
# ============================================================
# Copy this file to .env and adjust values for your setup.
# All SAKAPUSS_* variables are loaded by Pydantic Settings.

# --- Development URLs ---
TEST_ENV=local
BASE_URL=http://localhost:5173
API_URL=http://localhost:8000

# --- Application ---
SAKAPUSS_APP_NAME=sakapuss
SAKAPUSS_API_TITLE=Sakapuss API

# --- Database ---
# Path to SQLite database file (relative to project root)
SAKAPUSS_DB_PATH=./data/sakapuss.db

# --- Media Storage ---
# Path for pet photos and uploads
SAKAPUSS_MEDIA_PATH=./media

# --- MQTT / Home Assistant Integration ---
# Leave MQTT_BROKER_HOST empty to disable MQTT (app runs without it)
SAKAPUSS_MQTT_BROKER_HOST=
SAKAPUSS_MQTT_BROKER_PORT=1883
SAKAPUSS_MQTT_USERNAME=
SAKAPUSS_MQTT_PASSWORD=
SAKAPUSS_MQTT_DISCOVERY_PREFIX=homeassistant
